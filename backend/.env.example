# Copy this file to .env and fill in real values for local dev.
# In production (Render), set these as environment variables on the service.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Origin of the Next.js frontend (no trailing slash)
FRONTEND_ORIGIN=http://localhost:3000

# Optional in dev. Required in prod (otherwise images won't persist on Render).
# Get this from your Cloudinary dashboard → "API Environment variable".
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Optional. Defaults to local SQLite when unset.
# In production, Render injects this automatically from the linked database.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
