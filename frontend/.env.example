# Server-only: where Next.js (rewrite + Server Components) reaches Django.
# Browsers always call the API as `/api/*` on the Next.js origin; the
# rewrite in next.config.ts proxies those requests to this URL. That keeps
# session cookies same-origin even when web and api live on different
# subdomains in production.
#
# Local dev: http://localhost:8000
# Render:    your skillswap-api-XXXX.onrender.com URL
INTERNAL_API_URL=http://localhost:8000
